# Database Configuration - MariaDB
# Format: mysql://username:password@host:port/database
# NOTE: If your password contains special characters like $, escape them as $$ in Docker contexts

# Development database (used by `cargo loco start`)
DATABASE_URL=mysql://steadyinvest:your_password_here@localhost:3306/steadyinvest

# Test database (used by `cargo test` and CI)
# CI uses: mysql://steadyinvest:steadyinvest_test@localhost:3306/steadyinvest_test
# Local override example (NAS): mysql://steadyinvest:your_password@192.168.1.5:3306/steadyinvest_test
# If DATABASE_URL is set, it overrides backend/config/test.yaml default

# Database Connection Timeouts (in milliseconds)
# Increase these for external/remote databases
DB_CONNECT_TIMEOUT=5000
DB_IDLE_TIMEOUT=30000
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=5

# Loco Configuration
LOCO_ENV=development
LOCO_PORT=5150

# Frontend Configuration
LEPTOS_RELOAD_PORT=3001
